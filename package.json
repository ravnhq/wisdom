{
  "name": "wisdom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip:chrome": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:all": "pnpm zip:chrome && pnpm zip:firefox && pnpm validate:packages",
    "validate:packages": "node scripts/validate-extension-packages.mjs",
    "typecheck": "wxt prepare && tsc --noEmit",
    "check": "biome check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "pnpm typecheck && pnpm check && pnpm test && pnpm test:e2e && pnpm build && pnpm build:firefox"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/module-react": "^1.2.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wxt": "^0.20.25"
  }
}
